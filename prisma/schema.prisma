generator client {
  provider = "prisma-client-js"
}

// To generate an ERD diagram locally, uncomment this and run `npx prisma generate`:
// generator erd {
//   provider                  = "prisma-erd-generator"
//   output                    = "../docs/db-diagram.svg"
//   includeRelationFromFields = true
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Study {
  id          Int       @id @default(autoincrement())
  studyId     String?   @unique @map("study_id")
  title       String
  description String?
  sourceDir   String?   @map("source_dir")
  isHidden    Boolean   @default(false) @map("is_hidden")
  createdAt   DateTime  @default(now()) @map("created_at")

  cohorts  Cohort[]
  sessions StudySession[]

  @@map("studies")
}

model Cohort {
  id               Int      @id @default(autoincrement())
  cohortId         String   @map("cohort_id")
  label            String
  provider         String?
  model            String?
  fallbackProvider String?  @map("fallback_provider")
  fallbackModel    String?  @map("fallback_model")
  studyId          Int      @map("study_id")

  study        Study         @relation(fields: [studyId], references: [id], onDelete: Cascade)
  stages       Stage[]
  participants Participant[]

  @@unique([studyId, cohortId])
  @@map("cohorts")
}

model Stage {
  id          Int    @id @default(autoincrement())
  stageId     String @map("stage_id")
  title       String
  duration    Int    // seconds
  order       Int
  contentText String? @map("content_text")
  config      Json   @default("{}")  // everything else: chatbot, questions, input, link, confirmation, files, etc.
  cohortId    Int    @map("cohort_id")

  cohort         Cohort              @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  files          StageFile[]
  progress       ParticipantProgress[]
  chatLogs       ChatLog[]
  conversations  ChatConversation[]
  fallbackEvents FallbackEvent[]

  @@unique([cohortId, stageId])
  @@map("stages")
}

model StageFile {
  id          Int     @id @default(autoincrement())
  filename    String
  description String?
  sha256      String
  stageId     Int     @map("stage_id")

  stage Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@map("stage_files")
}

model StudySession {
  id        Int       @id @default(autoincrement())
  label     String?
  studyId   Int       @map("study_id")
  createdAt DateTime  @default(now()) @map("created_at")

  study        Study         @relation(fields: [studyId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@map("study_sessions")
}

model Participant {
  id         Int      @id @default(autoincrement())
  identifier String   @unique
  dbUser     String?  @unique @map("db_user")
  dbPassword String?  @map("db_password")
  isTestUser Boolean  @default(false) @map("is_test_user")
  name       String?
  sessionId  Int      @map("session_id")
  cohortId   Int      @map("cohort_id")
  createdAt  DateTime @default(now()) @map("created_at")

  session        StudySession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cohort         Cohort                @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  progress       ParticipantProgress[]
  chatLogs       ChatLog[]
  conversations  ChatConversation[]
  fallbackEvents FallbackEvent[]

  @@map("participants")
}

model ParticipantProgress {
  id            Int       @id @default(autoincrement())
  participantId Int       @map("participant_id")
  stageId       Int       @map("stage_id")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  responses     Json?     // flexible: {inputAnswer: "...", ratings: [...], etc.}

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  stage       Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([participantId, stageId])
  @@map("participant_progress")
}

model ChatConversation {
  id            Int      @id @default(autoincrement())
  threadId      String   @map("thread_id")      // widget thread ID
  participantId Int      @map("participant_id")
  stageId       Int      @map("stage_id")
  title         String?
  provider      String
  state         Json     // full SerializedConversation from SDK
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  stage       Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([participantId, threadId])
  @@map("chat_conversations")
}

model ChatLog {
  id             Int      @id @default(autoincrement())
  conversationId String   @map("conversation_id") // groups turns into a single chat session
  participantId  Int      @map("participant_id")
  stageId        Int      @map("stage_id")
  turnNumber     Int      @map("turn_number")
  role           String
  content        String
  provider       String?
  model          String?
  inputTokens    Int?     @map("input_tokens")
  outputTokens   Int?     @map("output_tokens")
  createdAt      DateTime @default(now()) @map("created_at")

  participant Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  stage       Stage         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  files       ChatFileLog[]

  @@map("chat_logs")
}

model ChatFileLog {
  id           Int      @id @default(autoincrement())
  chatLogId    Int      @map("chat_log_id")
  filename     String
  isKnownFile  Boolean  @default(false) @map("is_known_file")
  knownFileRef String?  @map("known_file_ref")
  base64Data   String?  @map("base64_data")
  mimeType     String?  @map("mime_type")
  sha256       String?

  chatLog ChatLog @relation(fields: [chatLogId], references: [id], onDelete: Cascade)

  @@map("chat_file_logs")
}

// Audit row written each time a chat thread switches from its primary
// provider to the cohort's configured fallback — fired by the widget's
// onFallbackUsed hook after a successful fallback.
model FallbackEvent {
  id                  Int      @id @default(autoincrement())
  threadId            String   @map("thread_id")
  participantId       Int      @map("participant_id")
  stageId             Int      @map("stage_id")
  reason              String   // "send-error" | "empty-exhausted"
  primaryProvider     String   @map("primary_provider")
  fallbackProvider    String   @map("fallback_provider")
  primaryErrorMessage String?  @map("primary_error_message")
  createdAt           DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  stage       Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([participantId, threadId])
  @@index([createdAt])
  @@map("fallback_events")
}
