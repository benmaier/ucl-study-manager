# Required: PostgreSQL connection string
# For the shared Neon database, ask the current maintainer.
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Required for admin panel (any string you choose for local dev)
ADMIN_PASSWORD=local-dev-password

# Optional: LLM API keys for chatbot stages
# Can also be managed via the database key pool (see README)
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIzaSy...
